# URL of the deployed API (only needed in production or when not using the dev proxy)
# In development, leave this unset and the Vite proxy will forward /api → http://localhost:3001
# VITE_API_URL=https://your-api.vercel.app

# Override the local dev proxy target (defaults to http://localhost:3001)
# VITE_API_PROXY_TARGET=http://localhost:3001
