# PostgreSQL connection string (pooled, used by Prisma at runtime)
DATABASE_URL=postgresql://user:password@host:5432/retro_board?pgbouncer=true

# Direct connection string (used by Prisma for migrations)
DIRECT_URL=postgresql://user:password@host:5432/retro_board

# Port the API server listens on (defaults to 3001)
PORT=3001
